# === 律 LINE bot 環境変数 ===

# --- Anthropic API ---
ANTHROPIC_API_KEY=sk-ant-...

# --- LINE Messaging API ---
RITSU_LINE_CHANNEL_SECRET=   # LINE Developers → チャネル → Channel Secret
RITSU_LINE_CHANNEL_TOKEN=    # LINE Developers → チャネル → Channel Access Token
RITSU_LINE_USER_ID=          # LINE Developers → プロバイダー → Your user ID

# --- サーバー ---
RITSU_LINE_PORT=9878
RITSU_LINE_BASE=/opt/ritsu-line

# --- 共有知識API ---
RITSU_KNOWLEDGE_API_TOKEN=    # ritsu_v4.pyからのsync認証用トークン
