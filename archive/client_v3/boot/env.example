# === Ritsu Worker 環境変数（テンプレート） ===
# コピーして .ritsu_worker.env として使用
# 実値は各自で設定すること

# --- 認証 ---
RITSU_BEARER_TOKEN=your_64char_token_here
RITSU_TOKEN=your_64char_token_here
RITSU_BASE_URL=http://127.0.0.1:18181

# --- OpenAI ---
OPENAI_API_KEY=sk-proj-your_key_here
RITSU_STT_API_KEY=sk-proj-your_key_here

# --- Worker ---
RITSU_WORKER_ID=gpc1

# --- 独り言（Monologue） ---
RITSU_MONOLOGUE_ENABLE=0
RITSU_MONOLOGUE_SCHEDULE_ENABLE=0
RITSU_MONOLOGUE_SCHEDULE_PATH=%USERPROFILE%\.ritsu\monologue_schedule.json
RITSU_MONOLOGUE_STOP_FILE=%USERPROFILE%\.ritsu\monologue_stop.txt
RITSU_MONOLOGUE_IDLE_SEC=600
RITSU_MONOLOGUE_COOLDOWN_SEC=900
RITSU_MONOLOGUE_MAX_PER_DAY=20
RITSU_MONOLOGUE_TIME_RANGE=08:00-23:59

# --- STT ---
RITSU_STT_LANG=ja
RITSU_STT_PROMPT=律、お願い、ありがとう、確認して
RITSU_STT_DEVICE=1
RITSU_STT_FS=16000

# --- VMC ---
RITSU_VMC_ENABLE=1
RITSU_VMC_HOST=127.0.0.1
RITSU_VMC_PORT=39539
RITSU_VMC_MAP_PATH=.\vmc_expr_map.json
RITSU_VMC_VALUE=1.0
RITSU_VMC_DEBUG=0
RITSU_VMC_FORCE=1
RITSU_VMC_HOLD_MS=1200
RITSU_VMC_SENDER=.\vmc_send_pyosc.py

# --- VOICEVOX ---
VOICEVOX_URL=http://127.0.0.1:50021
RITSU_VOICEVOX_SPEAKER_NAME=四国めたん
RITSU_TTS_STYLE=amaama

# --- AHK ---
RITSU_AHK_EXE=C:\Program Files\AutoHotkey\v2\AutoHotkey64.exe
